TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# LLM Provider configuration
LLM_PROVIDER=ollama          # ollama or xai
OLLAMA_MODEL=llama3.1:8b

# xAI API (only required when LLM_PROVIDER=xai)
XAI_API_KEY=
XAI_MODEL=grok-3-mini-beta

# Admin credentials for dashboard
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Lock the Telegram bot to a single account (optional)
# Find your ID: message @userinfobot on Telegram to get your numeric ID
ADMIN_TELEGRAM_ID=
SECRET_KEY=generate-with-python-secrets-token-hex-32

# Dashboard port (change if 8000 is taken)
DASHBOARD_PORT=8000